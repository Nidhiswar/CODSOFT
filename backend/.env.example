# Required
port=5009
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/db_name
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
CLIENT_URL=http://localhost:5173

# Optional (Features will be disabled if missing)
GOOGLE_API_KEY=your_google_api_key
EMAIL_USER=your_verified_sender_email@domain.com
BREVO_API_KEY=your_brevo_smtp_api_key
# Optional SMTP overrides (defaults target Brevo)
BREVO_SMTP_LOGIN=your_brevo_login_email
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
# Legacy fallback if BREVO_API_KEY is not set
EMAIL_PASS=legacy_smtp_password
